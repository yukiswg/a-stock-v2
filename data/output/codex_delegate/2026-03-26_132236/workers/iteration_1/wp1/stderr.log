+def _summarize_backtest(
+    trades: list[dict[str, Any]],
+    *,
+    equity_curve: list[float],
+    extras: dict[str, Any] | None = None,
+) -> dict[str, Any]:
+    max_drawdown = 0.0
+    peak = equity_curve[0]
