+    selection_score = _coerce_float(pick.get("selection_score"), best_stock.get("selection_score"))
+    lines.append(
+        f"- {name}({code}) | 交易结论 `{trade_action}` | 风格 `{strategy_style}` | 选择分 `{selection_score:.2f}`"
+    )
+    lines.append(
+        f"- 摘要: {pick.get('summary') or pick.get('thesis') or pick.get('reason') or '暂无摘要。'}"
+    )
+    lines.append(
+        f"- 回测摘要: 交易数 `{int(_coerce_float(backtest.get('trade_count'))):d}` | "
+        f"胜率 `{_coerce_float(backtest.get('win_rate')):.2%}` | "
+        f"平均收益 `{_coerce_float(backtest.get('average_return')):+.2%}`"
+    )
+    trades = list(backtest.get("trades") or [])
+    if trades:
+        latest = trades[0]
+        lines.append(
+            f"- 最近样本: {latest.get('name') or latest.get('code') or '未知'}"
+            f"({latest.get('code') or 'unknown'}) | "
+            f"`{latest.get('trade_action') or latest.get('decision') or '待确认'}` | "
+            f"次日 `{_coerce_float(latest.get('next_day_return')):+.2%}`"
+        )
+    return lines
+
+
+def _normalize_best_stock_payload(payload: dict[str, object]) -> dict[str, object]:
+    candidate = payload.get("best_stock")
+    if not isinstance(candidate, dict):
+        return {}
+    if isinstance(candidate.get("pick"), dict):
+        pick = dict(candidate.get("pick") or {})
+        backtest = dict(candidate.get("backtest") or {})
+        return {
+            "pick": pick,
+            "backtest": backtest,
+            "strategy_style": candidate.get("strategy_style") or pick.get("strategy_style"),
+            "selection_score": candidate.get("selection_score") or pick.get("selection_score"),
+        }
+    pick = dict(candidate)
+    backtest = dict(pick.get("backtest") or {})
+    return {
+        "pick": pick,
+        "backtest": backtest,
+        "strategy_style": pick.get("strategy_style"),
+        "selection_score": pick.get("selection_score"),
+    }
+
+
+def _coerce_float(*values: object) -> float:
+    for value in values:
+        if value in (None, ""):
+            continue
+        try:
+            return float(value)
+        except (TypeError, ValueError):
+            continue
+    return 0.0
+
