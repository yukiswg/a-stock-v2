+            float(item.get("selection_score") or 0.0),
+            float(item.get("win_rate") or 0.0),
+            float(item.get("average_return") or 0.0),
+            int(item.get("trade_count") or 0),
+        ),
+        reverse=True,
+    )
+    return rankings
+
+
+def _composite_score(
+    *,
+    selection_score: float,
+    trade_count: int,
+    win_rate: float,
+    average_return: float,
+) -> float:
+    sample_strength = min(max(trade_count, 0) / 3.0, 1.0) ** 2
+    history_component = sample_strength * (
+        (max(win_rate, 0.0) * 100.0 * 0.25)
+        + (average_return * 100.0 * 2.0)
+        + (min(max(trade_count, 0), 5) * 2.0)
+    )
+    return round((selection_score * 0.7) + history_component, 2)
